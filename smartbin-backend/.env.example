# Server
PORT=5000
NODE_ENV=development

# Database — use MongoDB Atlas URI for production (e.g. Render.com)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/smartbin
MONGODB_URI=mongodb://localhost:27017/smartbin

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
# Token expiry in seconds (604800 = 7 days)
JWT_EXPIRES_IN=604800

# Device API key — sent by the ESP8266 in the x-api-key header
DEVICE_API_KEY=change_this_to_a_random_device_key

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:3000
